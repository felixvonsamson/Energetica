{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Run",
            "type": "debugpy",
            "request": "launch",
            "program": "main.py",
            "console": "integratedTerminal",
            "args": [
                "--env", "prod", //maybe add a new test environment
                "--port", "5001",
                "--clock_time", "2",
                "--in_game_seconds_per_tick", "1800",
                "--run_init_test_players",
            ]
        },
        {
            "name": "Simulation",
            "type": "debugpy",
            "request": "launch",
            "program": "main.py",
            "console": "integratedTerminal",
            "args": [
                "--env", "dev", //maybe add a new test environment
                "--no-reload",
                "--port", "5001",
                "--simulate_file", "actions_history.log",
                "--simulate_checkpoint_every_k_ticks", "500",
                "--simulate_stop_on_mismatch",
                "--simulate_stop_on_server_error",
                "--simulate_stop_on_assertion_error",
                "--simulate_stop_on_unauthenticated_actions",
                //"--simulate_till", "512"

            ]
        }
    ]
}