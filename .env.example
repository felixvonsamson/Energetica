# .env.example — copy to .env and fill in values
# .env is gitignored; never commit secrets.

# ── Game configuration ─────────────────────────────────────────────────────────

# Seed test players on first startup (when instance/ is empty). Default: false
INIT_TEST_PLAYERS=false

# Tick speed: seconds of real time per game tick. Default: 30
# Allowed values: 1 2 3 4 5 6 10 12 15 20 30 60
CLOCK_TIME=30

# In-game seconds simulated per tick. Default: 240
# Allowed values: 60 120 180 240 300 360 420 480 540 600 900 1800 3600
IN_GAME_SECONDS_PER_TICK=240

# Disable new player sign-ups (useful for closed-group games). Default: false
DISABLE_SIGNUPS=false

# ── Production only (docker-compose.prod.yml) ──────────────────────────────────

# Your public domain name (used by Traefik for routing + Let's Encrypt)
DOMAIN=energetica.example.com

# Email for Let's Encrypt certificate notifications
LETSENCRYPT_EMAIL=admin@example.com
