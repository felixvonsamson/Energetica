{
    "name": "energetica",
    "version": "1.0.0",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "bash scripts/dev.sh app",
        "dev:lobby": "bash scripts/dev.sh lobby",
        "dev:login": "bash scripts/dev-login.sh",
        "serve:app": "bash scripts/dev-app.sh",
        "serve:app:fast": "bash scripts/dev-app.sh --clock_time 1 --in_game_seconds_per_tick 3600",
        "serve:app:test": "bash scripts/dev-app.sh --rm_instance --run_init_test_players",
        "serve:app:no-signup": "bash scripts/dev-app.sh --rm_instance --disable_signups",
        "serve:lobby": "bash scripts/dev-lobby.sh",
        "typecheck": "cd frontend && bun run typecheck",
        "typecheck:py": ".venv/bin/pyright --pythonpath \"$(pwd)/.venv/bin/python\"",
        "lint": "cd frontend && bun run lint",
        "format": "cd frontend && bun run format",
        "generate-types": "cd frontend && bun run generate-types",
        "ruff:check": ".venv/bin/ruff check energetica/ --fix",
        "ruff:format": ".venv/bin/ruff format energetica/",
        "check-wiki": ".venv/bin/python scripts/check_wiki_links.py",
        "rm-instance": "rm -rf instance/ checkpoints/ .energetica-dev/ frontend/public/instances.json",
        "deploy:game": "DEPLOY_HOST=energetica-game DEPLOY_DOMAIN=energetica-game.org bash scripts/deploy.sh --force --yes",
        "deploy:edu": "DEPLOY_HOST=energetica-edu DEPLOY_DOMAIN=energetica-edu.org bash scripts/deploy.sh --force --yes",
        "deploy:frontend:game": "DEPLOY_HOST=energetica-game DEPLOY_DOMAIN=energetica-game.org bash scripts/deploy.sh --force --yes --skip-backend",
        "deploy:frontend:edu": "DEPLOY_HOST=energetica-edu DEPLOY_DOMAIN=energetica-edu.org bash scripts/deploy.sh --force --yes --skip-backend",
        "deploy:reset:game": "DEPLOY_HOST=energetica-game DEPLOY_DOMAIN=energetica-game.org bash scripts/deploy.sh --force --yes --rm_instance",
        "deploy:reset:edu": "DEPLOY_HOST=energetica-edu DEPLOY_DOMAIN=energetica-edu.org bash scripts/deploy.sh --force --yes --rm_instance",
        "sync-instance:game": "rm -rf instance/ checkpoints/ && rsync -avz --delete energetica-game:/var/www/energetica/instance/ instance/",
        "sync-instance:edu": "rm -rf instance/ checkpoints/ && rsync -avz --delete energetica-edu:/var/www/energetica/instance/ instance/"
    }
}
