{
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "generate-types": "bash scripts/generate-types.sh",
        "lint:check": "eslint . --max-warnings 0",
        "pretty": "prettier --write \"./**/*.{ts,tsx}\"",
        "tsc:check": "tsc --noEmit"
    },
    "dependencies": {
        "@tailwindcss/vite": "^4.1.18",
        "@tanstack/react-query": "^5.90.12",
        "@tanstack/react-router": "^1.141.2",
        "@tanstack/router-plugin": "^1.141.2",
        "clsx": "^2.1.1",
        "lucide-react": "^0.525.0",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "recharts": "^3.5.1",
        "socket.io-client": "^4.8.1",
        "tailwind-merge": "^3.4.0",
        "tailwindcss": "^4.1.12"
    },
    "devDependencies": {
        "@types/node": "^24.10.3",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "@typescript-eslint/eslint-plugin": "^8.48.1",
        "@typescript-eslint/parser": "^8.48.1",
        "@vitejs/plugin-react": "^4.7.0",
        "baseline-browser-mapping": "^2.9.7",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsdoc": "^61.5.0",
        "eslint-plugin-react-hooks": "^7.0.1",
        "openapi-typescript": "^7.10.1",
        "prettier-plugin-jsdoc": "^1.8.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.49.0",
        "vite": "^7.2.7",
        "vite-plugin-dts": "^4.5.4"
    },
    "lint-staged": {
        "frontend/src/**/*.{ts,tsx}": [
            "npm run lint:check --prefix frontend"
        ],
        "frontend/**/*.{ts,tsx,js,jsx,json,css}": [
            "npm run pretty --prefix frontend"
        ]
    }
}
